<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Tree view for Attendance -->
    <record id="view_hikvision_attendance_tree" model="ir.ui.view">
        <field name="name">hikvision.attendance.tree</field>
        <field name="model">hikvision.attendance</field>
        <field name="arch" type="xml">
            <tree string="Attendance Records" decoration-danger="attendance_status == 'absent'" decoration-warning="attendance_status == 'incomplete'" decoration-success="attendance_status == 'present'">
                <field name="employee_id"/>
                <field name="date"/>
                <field name="attendance_status" widget="badge" decoration-success="attendance_status == 'present'" decoration-warning="attendance_status == 'incomplete'" decoration-danger="attendance_status == 'absent'"/>
                <field name="first_check_in"/>
                <field name="last_check_out"/>
                <field name="total_hours" widget="float_time"/>
                <field name="is_late" invisible="1"/>
                <field name="is_early_leave" invisible="1"/>
                <field name="late_minutes" string="Late (min)" optional="show"/>
                <field name="early_leave_minutes" string="Early (min)" optional="show"/>
                <field name="overtime_hours" widget="float_time" optional="show"/>
                <field name="approval_state" widget="badge" decoration-success="approval_state == 'approved'" decoration-warning="approval_state in ('to_approve', 'second_approval')" optional="show"/>
                <field name="status" widget="badge" decoration-info="status == 'in'" decoration-success="status == 'out'" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Form view for Attendance -->
    <record id="view_hikvision_attendance_form" model="ir.ui.view">
        <field name="name">hikvision.attendance.form</field>
        <field name="model">hikvision.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance Record">
                <header>
                    <button name="action_submit_ot" string="Submit OT" type="object" class="oe_highlight" invisible="approval_state != 'draft' or overtime_hours == 0"/>
                    <button name="action_first_approve" string="Approve (Manager)" type="object" class="oe_highlight" invisible="approval_state != 'to_approve'" groups="hikvision_attendance.group_hikvision_hr"/>
                    <button name="action_second_approve" string="Approve (HR)" type="object" class="oe_highlight" invisible="approval_state != 'second_approval'" groups="hikvision_attendance.group_hikvision_hr"/>
                    <button name="action_refuse_ot" string="Refuse" type="object" invisible="approval_state not in ('to_approve', 'second_approval')" groups="hikvision_attendance.group_hikvision_hr"/>
                    <field name="approval_state" widget="statusbar" statusbar_visible="draft,to_approve,second_approval,approved"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-clock-o" invisible="not is_late">
                            <field name="late_minutes" widget="statinfo" string="Late (min)"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-sign-out" invisible="not is_early_leave">
                            <field name="early_leave_minutes" widget="statinfo" string="Early (min)"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Present" bg_color="text-bg-success" invisible="attendance_status != 'present'"/>
                    <widget name="web_ribbon" title="Incomplete" bg_color="text-bg-warning" invisible="attendance_status != 'incomplete'"/>
                    <widget name="web_ribbon" title="Absent" bg_color="text-bg-danger" invisible="attendance_status != 'absent'"/>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="date"/>
                            <field name="attendance_status"/>
                        </group>
                        <group>
                            <field name="first_check_in"/>
                            <field name="last_check_out"/>
                            <field name="total_hours" widget="float_time"/>
                        </group>
                    </group>
                    <group string="Attendance Status">
                        <group>
                            <field name="is_late"/>
                            <field name="late_minutes" invisible="not is_late"/>
                        </group>
                        <group>
                            <field name="is_early_leave"/>
                            <field name="early_leave_minutes" invisible="not is_early_leave"/>
                        </group>
                    </group>
                    <group string="Overtime" invisible="overtime_hours == 0">
                        <group>
                            <field name="overtime_hours" widget="float_time" decoration-bf="1"/>
                            <field name="ot_payable_hours" widget="float_time" decoration-success="1" help="Calculated based on policy rates"/>
                        </group>
                        <group string="Approval Context">
                             <field name="ot_weekly_total" widget="float_time"/>
                             <field name="ot_monthly_total" widget="float_time"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_hikvision_attendance_search" model="ir.ui.view">
        <field name="name">hikvision.attendance.search</field>
        <field name="model">hikvision.attendance</field>
        <field name="arch" type="xml">
            <search string="Attendance">
                <field name="employee_id"/>
                <field name="date"/>
                <filter string="Today" name="today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="week" domain="[('date', '&gt;=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Present" name="present" domain="[('attendance_status', '=', 'present')]"/>
                <filter string="Incomplete" name="incomplete" domain="[('attendance_status', '=', 'incomplete')]"/>
                <filter string="Absent" name="absent" domain="[('attendance_status', '=', 'absent')]"/>
                <separator/>
                <filter string="Late" name="late" domain="[('is_late', '=', True)]"/>
                <filter string="Early Leave" name="early_leave" domain="[('is_early_leave', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Attendance" name="group_attendance" context="{'group_by': 'attendance_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hikvision_attendance" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">hikvision.attendance</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_hikvision_attendance_search"/>
        <field name="context">{'search_default_today': 1}</field>
    </record>
</odoo>


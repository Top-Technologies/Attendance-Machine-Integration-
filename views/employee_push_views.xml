<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- View for selecting employees to push -->
    <record id="view_employee_push_tree" model="ir.ui.view">
        <field name="name">hr.employee.push.tree</field>
        <field name="model">hr.employee</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <tree string="Select Employees to Push" multi_edit="1">
                <field name="name"/>
                <field name="barcode" string="Badge ID"/>
                <field name="department_id"/>
                <field name="company_id" column_invisible="1"/>
                <field name="job_id"/>
            </tree>
        </field>
    </record>

    <!-- Server action to push selected employees -->
    <record id="action_push_selected_to_device" model="ir.actions.server">
        <field name="name">Push to Hikvision Device</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="binding_model_id" ref="hr.model_hr_employee"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
# Get the first Hikvision device
device = env['hikvision.device'].search([], limit=1)
if not device:
    raise UserError("No Hikvision device configured. Please configure a device first.")

# Push selected employees
result = device.push_employees_by_ids(records.ids)
action = result
        </field>
    </record>

    <!-- Action to open employee selection for push -->
    <record id="action_select_employees_push" model="ir.actions.act_window">
        <field name="name">Select Employees to Push</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_employee_push_tree"/>
        <field name="target">current</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Select employees using checkboxes, then click Action → "Push to Hikvision Device"
            </p>
        </field>
    </record>
</odoo>

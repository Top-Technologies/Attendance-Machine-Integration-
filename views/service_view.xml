<odoo>

    <!-- FORM VIEW FOR SERVICE -->
    <record id="view_hikvision_service_form" model="ir.ui.view">
        <field name="name">hikvision.service.form</field>
        <field name="model">hikvision.service</field>
        <field name="arch" type="xml">
            <form string="Hikvision Service">
                <group>
                    <button name="fetch_all_users"
                            type="object"
                            string="Sync Device Users"
                            class="oe_highlight"/>
                </group>
            </form>
        </field>
    </record>

    <!-- ACTION TO OPEN SERVICE FORM -->
    <record id="action_hikvision_service" model="ir.actions.act_window">
        <field name="name">Sync Device Users</field>
        <field name="res_model">hikvision.service</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- MENU ITEM -->
    <menuitem id="menu_hikvision_service_sync"
              name="Sync Device Users"
              parent="menu_hikvision_root"
              action="action_hikvision_service"
              sequence="3"/>
</odoo>

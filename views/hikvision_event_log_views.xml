<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hikvision_event_log_tree" model="ir.ui.view">
        <field name="name">hikvision.event.log.tree</field>
        <field name="model">hikvision.event.log</field>
        <field name="arch" type="xml">
            <tree string="Live Events" create="false" edit="false" delete="false">
                <field name="timestamp"/>
                <field name="device_id"/>
                <field name="event_type"/>
                <field name="employee_no"/>
                <field name="employee_id"/>
            </tree>
        </field>
    </record>

    <record id="view_hikvision_event_log_form" model="ir.ui.view">
        <field name="name">hikvision.event.log.form</field>
        <field name="model">hikvision.event.log</field>
        <field name="arch" type="xml">
            <form string="Event Log" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="timestamp"/>
                            <field name="device_id"/>
                            <field name="event_type"/>
                        </group>
                        <group>
                            <field name="employee_no"/>
                            <field name="employee_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Raw Data">
                            <field name="raw_data"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hikvision_event_log_search" model="ir.ui.view">
        <field name="name">hikvision.event.log.search</field>
        <field name="model">hikvision.event.log</field>
        <field name="arch" type="xml">
            <search string="Search Events">
                <field name="device_id"/>
                <field name="employee_id"/>
                <field name="employee_no"/>
                <separator/>
                <filter string="Today" name="today" domain="[('event_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Month" name="this_month" domain="[('event_date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Device" name="group_device" context="{'group_by': 'device_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'event_date'}"/>
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hikvision_event_log" model="ir.actions.act_window">
        <field name="name">Live Events</field>
        <field name="res_model">hikvision.event.log</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_hikvision_event_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No events found yet.
            </p>
            <p>
                Events from connected devices will appear here in real-time.
            </p>
        </field>
    </record>

    <menuitem id="menu_hikvision_event_log"
              name="Live Events"
              parent="hikvision_attendance.menu_hikvision_root"
              action="action_hikvision_event_log"
              sequence="20"/>
</odoo>
